{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://aguirreaudiffred.github.io/margin-client-system/",
      "permanent": false
    },
    {
      "source": "/((?!api/).*)",
      "destination": "https://aguirreaudiffred.github.io/margin-client-system/$1",
      "permanent": false
    }
  ]
}
